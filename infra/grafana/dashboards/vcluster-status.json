{
  "uid": "pact-vcluster-status",
  "title": "Pact vCluster Status",
  "description": "Nodes per vCluster, policy versions, drift, emergency mode, and approval queues",
  "tags": ["pact", "vcluster", "policy"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0
      },
      {
        "name": "vcluster",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(pact_vcluster_nodes_total, vcluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Nodes per vCluster",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_vcluster_nodes_total{vcluster=~\"$vcluster\"}",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 2,
      "title": "Policy Version per vCluster",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_vcluster_policy_version{vcluster=~\"$vcluster\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "vcluster" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "vcluster": "vCluster", "Value": "Policy Version" }
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Drift per vCluster",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (vcluster) (pact_agent_drift_magnitude{vcluster=~\"$vcluster\"})",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Emergency Mode Status",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_vcluster_emergency_mode{vcluster=~\"$vcluster\"}",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Normal", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Emergency", "color": "red" } } }
          ]
        }
      },
      "options": {
        "showValue": "always",
        "alignValue": "center",
        "rowHeight": 0.8
      }
    },
    {
      "id": 5,
      "title": "Approval Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_vcluster_approval_queue_depth{vcluster=~\"$vcluster\"}",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "bars"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "title": "Drifted Nodes per vCluster",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count by (vcluster) (pact_agent_config_state{vcluster=~\"$vcluster\", state=\"drifted\"})",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
