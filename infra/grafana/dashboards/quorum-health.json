{
  "uid": "pact-quorum-health",
  "title": "Pact Raft Quorum Health",
  "description": "Raft role, leader elections, log replication, snapshots, and peer connectivity",
  "tags": ["pact", "raft", "quorum"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openraft_server_state, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Raft Role per Node",
      "type": "state-timeline",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "openraft_server_state{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-blues" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Follower", "color": "blue" } } },
            { "type": "value", "options": { "1": { "text": "Candidate", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "Leader", "color": "green" } } }
          ]
        }
      },
      "options": {
        "showValue": "always",
        "alignValue": "center",
        "rowHeight": 0.8
      }
    },
    {
      "id": 2,
      "title": "Leader Changes Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "changes(openraft_leader_id{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} leader changes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Current Term",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(openraft_current_term{instance=~\"$instance\"})",
          "legendFormat": "term"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "title": "Committed Log Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(openraft_commit_index{instance=~\"$instance\"})",
          "legendFormat": "commit index"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Log Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "openraft_last_log_index{instance=~\"$instance\"} - on() group_left() max(openraft_commit_index{instance=~\"$instance\"})",
          "legendFormat": "{{instance}} lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "title": "Snapshot Frequency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(openraft_snapshot_index{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} snapshot rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "title": "Peer Connectivity",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "openraft_replication_target{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "instance" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true },
            "renameByName": { "instance": "Source", "target": "Peer", "Value": "Connected" }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
