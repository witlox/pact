{
  "uid": "pact-journal-overview",
  "title": "Pact Journal Overview",
  "description": "Journal entries, boot streams, overlay builds, and Raft state",
  "tags": ["pact", "journal", "raft"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(pact_journal_entries_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Journal Entries Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_journal_entries_total{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Active Boot Streams",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(pact_journal_boot_streams_active{instance=~\"$instance\"})",
          "legendFormat": "active streams"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Boot Streams per Instance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "pact_journal_boot_streams_active{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Overlay Builds Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(pact_journal_overlay_builds_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Raft State",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "openraft_server_state{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - {{state}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "state" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Leader": { "text": "Leader", "color": "green" } } },
                  { "type": "value", "options": { "Follower": { "text": "Follower", "color": "blue" } } },
                  { "type": "value", "options": { "Candidate": { "text": "Candidate", "color": "yellow" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "instance" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": false, "__name__": true, "job": true },
            "renameByName": { "instance": "Instance", "state": "Raft Role", "Value": "Active" }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Entries per vCluster",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (vcluster) (pact_journal_entries_total{instance=~\"$instance\"})",
          "legendFormat": "{{vcluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "id": 7,
      "title": "Overlay Builds Total",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(pact_journal_overlay_builds_total{instance=~\"$instance\"})",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
